# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Admin Panel
# Email of the admin user — only this account can access /admin
ADMIN_EMAIL=your_admin_email@example.com
# Service role key — used ONLY in /api/admin/* routes (server-side, never sent to browser)
# Find in Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
